# Bakery ordering platform demo environment variables
# Copy this file to .env.local for local development.
# Demo/test only: do not use live Stripe keys or production customer data.

# Supabase demo project
# Create a separate development/test Supabase project for this demo.
NEXT_PUBLIC_SUPABASE_URL=https://your-demo-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe test mode only
# Get these from the Stripe Dashboard while Test mode is enabled.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Safety guard: live Stripe secret keys are rejected unless this is explicitly true.
ALLOW_LIVE_PAYMENTS=false

# Stripe webhook secret
# Local: from `stripe listen`
# Demo site: from a Stripe test-mode webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# App demo URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-string

# Email
# Optional during development. Required if you want confirmation/reminder emails.
RESEND_API_KEY=re_...
EMAIL_FROM=orders@yourbakery.com

# Admin demo account
# Create an admin user in Supabase Auth, then set profiles.role = 'admin' in SQL.

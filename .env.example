# Bakery ordering platform environment variables
# Copy this file to .env.local for local development.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret
# Local: from `stripe listen`
# Production: from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-string

# Email
# Optional during development. Required if you want confirmation/reminder emails.
RESEND_API_KEY=re_...
EMAIL_FROM=orders@yourbakery.com

# Admin
# Create an admin user in Supabase Auth, then set profiles.role = 'admin' in SQL.
